GROQ_API_KEY=your_groq_api_key_here
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# --- Data layer (DPDP consent storage + anonymized aggregates) ---
# Neon Postgres connection string
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require
# AES-256 key, base64 of 32 random bytes:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
DATA_ENC_KEY=your_base64_32_byte_key
# Bearer token gating the admin aggregate export (/api/admin/insights)
ADMIN_TOKEN=set_a_long_random_string
# Secret gating the scheduled aggregation job (/api/cron/aggregate)
CRON_SECRET=set_another_long_random_string

# Google Apps Script webhook for exporting consented readings to a Sheet (optional)
GOOGLE_SHEET_WEBHOOK=https://script.google.com/macros/s/XXXX/exec
